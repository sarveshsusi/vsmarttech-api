# Copy to .env for local development. Never commit real secrets.

SERVER_PORT=8080
APP_ENV=development
RATE_LIMIT_MAX=60

# DB pool (tune down further on 1GB Lightsail)
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=3
DB_CONN_MAX_LIFETIME_MINUTES=30
RUN_INPROCESS_CRONS=true
TRUSTED_PROXIES=nginx,172.16.0.0/12,10.0.0.0/8

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vsmartcrm_db?sslmode=disable
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vsmartcrm_db

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

FRONTEND_URL=http://localhost:5173
REMEMBER_DEVICE_SECRET=dev-device-secret-change-me

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=rbac@app.com

STORAGE_TYPE=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_BASE_URL=http://localhost:8080/uploads

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_FOLDER=uploads

IMAGE_MAX_SIZE_BYTES=1048576
IMAGE_COMPRESS_THRESHOLD_BYTES=51200
IMAGE_QUALITY=85
