# Ignore everything not needed inside the Docker build context
# This keeps the image small and avoids leaking secrets

.env
.env.*
!.env.example
!.env.production.example
.git
.gitignore
docker-compose*.yml
Dockerfile*
.dockerignore

# Local binaries / artifacts
main/main
app
server
bin/
*.tar
myapp-api.tar
*.log

# Local uploads (S3 is used in production)
uploads/

# Docs / scripts not needed in the image
*.md
DEPLOY_LIGHTSAIL.md
scripts/
nginx/
openapi.yaml
