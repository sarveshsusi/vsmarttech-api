# ==============================================================
# PRODUCTION ENVIRONMENT — Copy this file to .env on your NAS
# Never commit this file with real secrets to git
# ==============================================================

# =====================
# Server
# =====================
SERVER_PORT=8080
APP_ENV=production
RATE_LIMIT_MAX=1000
# Compose runs worker-sla + worker-contracts — keep false there
RUN_INPROCESS_CRONS=false
TRUSTED_PROXIES=nginx,172.16.0.0/12,10.0.0.0/8

# =====================
# Database (PostgreSQL container)
# The backend reads DATABASE_URL; the postgres container reads POSTGRES_* vars
# Keep POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB consistent below
# =====================
DATABASE_URL=postgresql://prod_user:CHANGE_ME_DB_PASSWORD@postgres:5432/vsmartcrm_db

POSTGRES_USER=prod_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=vsmartcrm_db

# =====================
# JWT — generate strong random secrets, e.g.:
#   openssl rand -hex 64
# =====================
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# =====================
# Frontend (Vercel deployment URL)
# Used for CORS, password-reset emails, and Content-Security-Policy
# =====================
FRONTEND_URL=https://your-app.vercel.app

# =====================
# Remember Device Secret — generate with:
#   openssl rand -hex 64
# =====================
REMEMBER_DEVICE_SECRET=CHANGE_ME_DEVICE_SECRET

# =====================
# Mail (SMTP)
# =====================
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=api
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_FROM=no-reply@yourdomain.com

# =====================
# AWS S3 (file uploads / attachments)
# =====================
STORAGE_TYPE=s3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET
AWS_S3_BUCKET=vsproofs
AWS_S3_FOLDER=uploads

# =====================
# Image compression
# =====================
IMAGE_MAX_SIZE_BYTES=1048576
IMAGE_COMPRESS_THRESHOLD_BYTES=51200
IMAGE_QUALITY=85
